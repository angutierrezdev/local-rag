# Ollama Configuration (REQUIRED)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# ChromaDB Configuration
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION_NAME=restaurant_reviews_ts
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# ChromaDB Docker Configuration (for docker-compose.yml - REQUIRED for healthcheck)
CHROMA_SERVER_HOST=0.0.0.0
CHROMA_SERVER_HTTP_PORT=8000
CHROMA_HEALTHCHECK_URL=http://localhost:8000/api/v1/heartbeat

# Data Configuration
CSV_FILE_PATH=realistic_restaurant_reviews.csv

# Prompts Configuration
PROMPTS_CONFIG_PATH=prompts/default.json

# Chat History Configuration
# Number of messages to keep in chat history (default: 10)
# Higher values provide more context but use more tokens
CHAT_WINDOW_SIZE=10

# Folder Watcher Configuration
# Host path to the API drive folder — used as the watch target locally and mounted into Docker at /watched
# Example: /Users/yourname/Projects/Angular/Dactil/Clients/api/drive
API_DRIVE_PATH=/path/to/api/drive
# Use polling mode for file watching — required for Docker on macOS (default: true)
WATCH_POLLING=true

# Debug Configuration
DEBUG_VECTOR_TEST=false
